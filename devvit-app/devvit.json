{
  "$schema": "https://developers.reddit.com/schema/config-file.v1.json",
  "name": "modpilotdemo",
  "server": {
    "dir": "dist/server",
    "entry": "index.cjs"
  },
  "post": {
    "dir": "dist/client",
    "entrypoints": {
      "default": { "entry": "index.html" }
    }
  },
  "menu": {
    "items": [
      {
        "label": "Investigate with ModPilot",
        "description": "Run a full investigation on this comment.",
        "location": "comment",
        "forUserType": "moderator",
        "endpoint": "/internal/menu/investigate-comment"
      },
      {
        "label": "Investigate with ModPilot",
        "description": "Run a full investigation on this post.",
        "location": "post",
        "forUserType": "moderator",
        "endpoint": "/internal/menu/investigate-post"
      },
      {
        "label": "ModPilot: Configure policy",
        "description": "Set the rules, personality, and investigation depth ModPilot uses on this subreddit.",
        "location": "subreddit",
        "forUserType": "moderator",
        "endpoint": "/internal/menu-config/open"
      },
      {
        "label": "ModPilot: Stats",
        "description": "Subreddit-wide moderation stats: investigations run, alignment rate, total cost.",
        "location": "subreddit",
        "forUserType": "moderator",
        "endpoint": "/internal/menu-stats/open"
      }
    ]
  },
  "forms": {
    "wipeMemory": "/internal/form/wipe-memory-submit",
    "verdictView": "/internal/form/verdict-view-submit",
    "configurePolicy": "/internal/menu-config/submit"
  },
  "triggers": {
    "onAppInstall": "/internal/triggers/on-app-install",
    "onAppUpgrade": "/internal/triggers/on-app-upgrade",
    "onCommentReport": "/internal/triggers/on-comment-report",
    "onPostReport": "/internal/triggers/on-post-report",
    "onModAction": "/internal/triggers/on-mod-action"
  },
  "scheduler": {
    "tasks": {
      "priorityRollup": {
        "cron": "*/5 * * * *",
        "endpoint": "/internal/scheduler/priority-rollup"
      },
      "feedbackBatch": {
        "cron": "0 4 * * *",
        "endpoint": "/internal/scheduler/feedback-batch"
      }
    }
  },
  "scripts": {
    "build": "vite build",
    "dev": "vite build --watch"
  },
  "dev": {
    "subreddit": "ModPilotDev"
  },
  "permissions": {
    "reddit": true,
    "redis": true,
    "http": {
      "enable": true,
      "domains": ["generativelanguage.googleapis.com"]
    }
  }
}
