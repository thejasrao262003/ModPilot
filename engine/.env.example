# ModPilot Investigation Engine — environment template
# Copy to `.env` and fill in real values. NEVER commit `.env`.

# === LLM ===
GEMINI_API_KEY=
MODEL_REASONER=gemini-2.5-pro
MODEL_SUMMARIZER=gemini-2.5-flash

# === Datastores ===
DATABASE_URL=postgresql+asyncpg://modpilot:modpilot@localhost:5432/modpilot
REDIS_URL=redis://localhost:6379/0

# === HMAC signing (Devvit ↔ Engine) ===
ENGINE_SHARED_SECRET=

# === Observability ===
LOG_LEVEL=INFO
GRAFANA_CLOUD_API_KEY=

# === Budgets ===
DAILY_SPEND_CAP_USD=15.0
DAILY_SPEND_CAP_PER_SUB_USD=2.0

# === Feature flags ===
ENV=development
ENABLE_LIVE_LLM_TESTS=false
